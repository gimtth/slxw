<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sl_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="返回"
            android:textColor="@color/sl_news_blue"
            android:textSize="@dimen/text_body" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="新闻详情"
            android:textColor="@color/sl_text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCollect"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical|end"
            android:text="收藏"
            android:textColor="@color/sl_news_blue"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_lg">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/sl_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/sl_text_secondary"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/tvState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:textColor="@color/sl_text_secondary"
                android:textSize="@dimen/text_body" />

            <WebView
                android:id="@+id/webContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@color/sl_background" />

            <Button
                android:id="@+id/btnOpenOriginal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_outline_button"
                android:stateListAnimator="@null"
                android:text="查看原文"
                android:textColor="@color/sl_news_blue"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
