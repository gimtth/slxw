<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sl_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg">

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="返回"
                android:textColor="@color/sl_news_blue"
                android:textSize="@dimen/text_body" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="修改密码"
                android:textColor="@color/sl_text_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <Space
                android:layout_width="48dp"
                android:layout_height="match_parent" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="为了账号安全，请先输入当前密码。"
                android:textColor="@color/sl_text_secondary"
                android:textSize="@dimen/text_body" />

            <EditText
                android:id="@+id/etOldPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_xl"
                android:background="@drawable/bg_edit_text"
                android:hint="当前密码"
                android:inputType="textPassword"
                android:singleLine="true"
                android:textColor="@color/sl_text_primary"
                android:textColorHint="@color/sl_text_secondary" />

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_edit_text"
                android:hint="新密码"
                android:inputType="textPassword"
                android:singleLine="true"
                android:textColor="@color/sl_text_primary"
                android:textColorHint="@color/sl_text_secondary" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/confirm_password"
                android:inputType="textPassword"
                android:singleLine="true"
                android:textColor="@color/sl_text_primary"
                android:textColorHint="@color/sl_text_secondary" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_xl"
                android:text="保存新密码" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
